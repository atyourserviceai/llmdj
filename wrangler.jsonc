{
  "name": "llmdj",
  "main": "src/server.ts",
  "compatibility_date": "2025-05-07",
  "compatibility_flags": [
    "nodejs_compat",
    "nodejs_compat_populate_process_env",
  ],
  "assets": {
    "directory": "public",
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "AppAgent",
        "class_name": "AppAgent",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["AppAgent"],
    },
  ],
  "vars": {
    "GATEWAY_BASE_URL": "https://gateway.atyourservice.ai",
    "SETTINGS_ENVIRONMENT": "dev",
    "COMPOSIO_API_KEY": "",
    "BROWSERBASE_API_KEY": "",
    "SPOTIFY_CLIENT_ID": "",
    "SPOTIFY_CLIENT_SECRET": "",
    "SPOTIFY_REDIRECT_URI": "https://llmdj-dev.atyourservice.ai/auth/callback",
  },
  "env": {
    "staging": {
      "vars": {
        "GATEWAY_BASE_URL": "https://gateway.atyourservice.ai",
        "SETTINGS_ENVIRONMENT": "staging",
        "COMPOSIO_API_KEY": "",
        "BROWSERBASE_API_KEY": "",
        "SPOTIFY_CLIENT_ID": "",
        "SPOTIFY_CLIENT_SECRET": "",
        "SPOTIFY_REDIRECT_URI": "https://llmdj-staging.atyourservice.ai/auth/callback",
      },
      "routes": [
        {
          "pattern": "llmdj-staging.atyourservice.ai",
          "custom_domain": true,
        },
      ],
    },
    "production": {
      "vars": {
        "GATEWAY_BASE_URL": "https://gateway.atyourservice.ai",
        "SETTINGS_ENVIRONMENT": "production",
        "COMPOSIO_API_KEY": "",
        "BROWSERBASE_API_KEY": "",
        "SPOTIFY_CLIENT_ID": "",
        "SPOTIFY_CLIENT_SECRET": "",
        "SPOTIFY_REDIRECT_URI": "https://llmdj.atyourservice.ai/auth/callback",
      },
      "routes": [
        {
          "pattern": "llmdj.atyourservice.ai",
          "custom_domain": true,
        },
      ],
    },
  },
}
